# Database (shared-db PostgreSQL)
DATABASE_URL=postgresql://postgres:0000@postgres:5433/portal_auth?schema=public

# JWT — ใช้ PORTAL_JWT_SECRET เดียวกันทุกโปรเจกค์เพื่อให้ validate SSO token ข้ามโปรเจกค์ได้
JWT_SECRET=change_me_in_production_use_same_value_across_all_projects
PORTAL_JWT_SECRET=change_me_in_production_use_same_value_across_all_projects

# Cookie
COOKIE_SECURE=false

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3090

# Sub-project URLs (ใช้สำหรับ Dashboard card links + SSO redirect)
ACCOUNT_A_TEAM_URL=http://localhost:3000/account
MANAGEMENT_TRACKING_URL=http://localhost:8090
TEAM_PERFORMANCE_URL=http://localhost:3080
